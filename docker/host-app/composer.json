{
    "name": "escalated-dev/escalated-filament-demo-host",
    "type": "project",
    "description": "Minimal Laravel host app used only to demo escalated-dev/escalated-filament. Not shipped.",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "escalated-dev/escalated-laravel": "^1.2",
        "escalated-dev/escalated-filament": "@dev",
        "fakerphp/faker": "^1.23",
        "filament/filament": "^4.0",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    },
    "repositories": [
        {
            "type": "path",
            "url": "/package",
            "options": {
                "symlink": false
            }
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "8.3.30"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
