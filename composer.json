{
    "name": "escalated-dev/escalated-filament",
    "description": "Filament admin panel integration for the Escalated support ticket system",
    "keywords": ["laravel", "filament", "support", "tickets", "helpdesk", "customer-support"],
    "license": "MIT",
    "type": "library",
    "repositories": [
        {"type": "vcs", "url": "https://github.com/escalated-dev/escalated-locale"}
    ],
    "require": {
        "php": "^8.2",
        "escalated-dev/escalated-laravel": "dev-main as 1.4.0",
        "escalated-dev/locale": "^0.1",
        "filament/filament": "^4.0 || ^5.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0"
    },
    "autoload": {
        "files": [
            "src/compat.php"
        ],
        "psr-4": {
            "Escalated\\Filament\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Escalated\\Filament\\Tests\\": "tests/",
            "Escalated\\Laravel\\Database\\Factories\\": "vendor/escalated-dev/escalated-laravel/database/factories/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php scripts/apply-livewire-view-errorbag-patch.php"
        ],
        "post-update-cmd": [
            "@php scripts/apply-livewire-view-errorbag-patch.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Escalated\\Filament\\EscalatedFilamentServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "conflict": {
        "filament/filament": ">=5.5.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
